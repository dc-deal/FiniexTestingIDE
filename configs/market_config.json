{
    "version": "1.0",
    "description": "FiniexTestingIDE - Market Configuration",
    "market_rules": {
        "forex": {
            "weekend_closure": true,
            "session_bucketing": true,
            "primary_activity_metric": "tick_count",
            "inter_tick_gap_threshold_s": 300,
            "profile_defaults": {
                "min_block_hours": 2,
                "max_block_hours": 24,
                "atr_percentile_threshold": 10
            }
        },
        "crypto": {
            "weekend_closure": false,
            "session_bucketing": false,
            "primary_activity_metric": "volume",
            "inter_tick_gap_threshold_s": 600,
            "profile_defaults": {
                "min_block_hours": 4,
                "max_block_hours": 72,
                "atr_percentile_threshold": 15
            }
        }
    },
    "brokers": [
        {
            "broker_type": "mt5",
            "market_type": "forex",
            "broker_config_path": "./configs/brokers/mt5/mt5_broker_config.json"
        },
        {
            "broker_type": "kraken_spot",
            "market_type": "crypto",
            "broker_config_path": "./configs/brokers/kraken/kraken_spot_broker_config.json"
        }
    ]
}