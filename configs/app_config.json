{
    "version": "1.2.3",
    "description": "FiniexTestingIDE - Application Configuration",
    "development": {
        "dev_mode": false
    },
    "console_logging": {
        "enabled": true,
        "log_level": "INFO",
        "warn_on_parameter_override": true,
        "scenario": {
            "enabled": false,
            "log_level": "WARNING",
            "write_system_info": true
        },
        "summary": {
            "show_global_log": false,
            "detail": false,
            "scenario_detail_threshold": 9
        }
    },
    "file_logging": {
        "enabled": true,
        "log_level": "DEBUG",
        "log_path": "logs/",
        "append_mode": true,
        "scenario": {
            "enabled": true,
            "log_level": null,
            "log_root_path": "logs/scenario_sets",
            "file_name_prefix": "scenario"
        }
    },
    "paths": {
        "data_processed": "data/processed",
        "user_algo_dirs": [
            "user_algos/"
        ]
    },
    "history": {
        "bar_max_history": 1000,
        "order_history_max": 10000,
        "trade_history_max": 5000
    },
    "autotrader": {
        "execution": {
            "parallel_workers": false,
            "bar_max_history": 1000,
            "performance_tracking": {
                "worker_decision_tracking": true
            }
        },
        "clipping_monitor": {
            "report_interval_s": 60.0,
            "strategy": "queue_all"
        },
        "display": {
            "enabled": true,
            "update_interval_ms": 300
        },
        "order_guard": {
            "cooldown_seconds": 60.0,
            "max_consecutive_rejections": 2
        },
        "drift_audit": {
            "enabled": true,
            "fee_threshold_pct": 0.5,
            "volume_threshold_pct": 0.1,
            "price_threshold_pct": 1.0,
            "slippage_threshold_pct": 0.5,
            "log_all": false,
            "sample_rate": 1.0
        }
    },
    "backtesting": {
        "execution": {
            "parallel_scenarios": true,
            "max_parallel_scenarios": 99,
            "default_scenario_execution_config": {
                "parallel_workers": false,
                "worker_parallel_threshold_ms": 1.0,
                "adaptive_parallelization": true,
                "performance_tracking": {
                    "tick_loop_profiling": true,
                    "worker_decision_tracking": false
                },
                "strict_parameter_validation": true,
                "tick_processing_budget_ms": 0.0
            }
        },
        "default_trade_simulator_config": {
            "balances": {},
            "seeds": {
                "inbound_latency_seed": 42
            },
            "inbound_latency_min_ms": 20,
            "inbound_latency_max_ms": 80
        },
        "monitoring": {
            "enabled": true,
            "tui_refresh_rate_ms": 300,
            "detailed_live_stats": true,
            "detailed_live_stats_threshold": 3,
            "detailed_live_stats_exports": {
                "export_portfolio_stats": false,
                "export_performance_stats": false,
                "export_current_bars": false
            },
            "event_tape_size": 5
        },
        "data_validation": {
            "warmup_quality_mode": "standard",
            "allowed_gap_categories": [
                "seamless",
                "short",
                "weekend",
                "holiday"
            ]
        },
        "paths": {
            "scenario_sets": "configs/scenario_sets",
            "brokers": "configs/brokers",
            "generator_template": "configs/generator/template_scenario_set_header.json",
            "generator_output": "configs/scenario_sets"
        }
    }
}