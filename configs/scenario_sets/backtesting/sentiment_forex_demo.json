{
    "version": "1.0",
    "scenario_set_name": "sentiment_forex_demo",
    "description": "SIGNAL worker on FOREX (mt5/EURUSD) with the mock forex_macro_sentiment source (#429). Two things on purpose: (1) the data_sentiment_type pipeline on a SECOND market/broker; (2) graceful degradation — the scenario window (2026-05-03T23:00 → 05-04T02:00) straddles the sentiment coverage end (…05-03T23:50), so the tail runs on STALE sentiment → the hybrid decision falls back to pure-indicator mode (worker is_stale=True). Didactic: hybrid_sentiment_reference is crypto-recommended, so a soft market-fit warning is expected; forex sentiment here is random mock. Not a profit claim.",
    "global": {
        "data_mode": "realistic",
        "strategy_config": {
            "decision_logic_type": "CORE/hybrid_sentiment_reference",
            "worker_instances": {
                "rsi_fast": "CORE/rsi",
                "sentiment": "CORE/llm_sentiment"
            },
            "workers": {
                "rsi_fast": {
                    "periods": {
                        "M5": 14
                    }
                },
                "sentiment": {
                    "max_staleness_minutes": 30
                }
            },
            "decision_logic_config": {
                "rsi_buy_threshold": 35,
                "rsi_sell_threshold": 65,
                "lot_size": 0.01,
                "min_free_margin": 100
            }
        },
        "execution_config": {
            "parallel_workers": false
        },
        "trade_simulator_config": {
            "balances": {
                "USD": 10000
            }
        }
    },
    "scenarios": [
        {
            "name": "EURUSD_sentiment_forex_scenario_01",
            "symbol": "EURUSD",
            "data_broker_type": "mt5",
            "data_sentiment_type": "forex_macro_sentiment",
            "start_date": "2026-05-03T23:00:00+00:00",
            "end_date": "2026-05-04T02:00:00+00:00",
            "max_ticks": 15000,
            "data_mode": "realistic",
            "enabled": true,
            "strategy_config": {},
            "execution_config": {},
            "trade_simulator_config": {}
        },
        {
            "name": "EURUSD_sentiment_forex_scenario_02",
