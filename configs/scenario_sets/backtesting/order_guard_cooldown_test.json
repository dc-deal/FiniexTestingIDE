{
    "version": "1.0",
    "scenario_set_name": "order_guard_cooldown_test",
    "created": "2026-04-08T00:00:00.000000",
    "description": "OrderGuard Rejection Cooldown — Verifies that consecutive broker rejections arm the cooldown and subsequent orders are blocked by the guard",
    "global": {
        "data_mode": "realistic",
        "strategy_config": {
            "decision_logic_type": "CORE/backtesting/backtesting_margin_stress",
            "worker_instances": {
                "backtesting_worker": "CORE/backtesting/backtesting_sample_worker"
            },
            "workers": {
                "backtesting_worker": {
                    "periods": {
                        "M5": 14,
                        "M30": 20
                    },
                    "bar_snapshot_checks": []
                }
            },
            "decision_logic_config": {
                "trade_sequence": [
                    {
                        "tick_number": 100,
                        "direction": "LONG",
                        "lot_size": 1.0,
                        "hold_ticks": 9000,
                        "_comment": "Trade #0: First LONG — consumes ~28,800 JPY margin"
                    },
                    {
                        "tick_number": 200,
                        "direction": "LONG",
                        "lot_size": 1.0,
                        "hold_ticks": 9000,
                        "_comment": "Trade #1: Second LONG — total ~57,600 JPY, free ~22,400"
                    },
                    {
                        "tick_number": 400,
                        "direction": "LONG",
                        "lot_size": 1.0,
                        "expect_rejection": true,
                        "_comment": "Trade #2: REJECTED — INSUFFICIENT_MARGIN (broker). Guard counter=1 → cooldown armed (threshold=1)"
                    },
                    {
                        "tick_number": 600,
                        "direction": "LONG",
                        "lot_size": 1.0,
                        "expect_rejection": true,
                        "_comment": "Trade #3: REJECTED by guard — REJECTION_COOLDOWN (never reaches broker)"
                    }
                ],
                "close_events": [],
                "retry_events": [],
                "edge_case_orders": [],
                "lot_size": 1.0
            }
        },
        "execution_config": {
            "parallel_workers": false,
            "log_performance_stats": true
        },
        "trade_simulator_config": {
            "balances": { "JPY": 80000 },
            "seeds": {
                "inbound_latency_seed": 42424
            }
        },
        "order_guard": {
            "_comment": "Explicit guard config — max_consecutive_rejections=1 makes a single INSUFFICIENT_MARGIN rejection arm the cooldown, decoupling the test from the framework default. cooldown_seconds is measured in SIMULATED (tick) time, not wall-clock: at ~18s/tick this scenario spans ~1h between the rejecting trade and the follow-up, so the cooldown must cover the full scenario window to ensure Trade #3 still sees the armed cooldown.",
            "cooldown_seconds": 86400.0,
            "max_consecutive_rejections": 1
        }
    },
    "scenarios": [
        {
            "name": "USDJPY_order_guard_cooldown",
            "symbol": "USDJPY",
            "data_broker_type": "mt5",
            "start_date": "2025-09-25T16:00:00+00:00",
            "end_date": "2025-09-26T02:00:00+00:00",
            "max_ticks": 2000,
            "data_mode": "realistic",
            "enabled": true,
            "strategy_config": {},
            "execution_config": {},
            "trade_simulator_config": {}
        }
    ]
}
