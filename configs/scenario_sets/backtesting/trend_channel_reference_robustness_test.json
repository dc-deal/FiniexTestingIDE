  "version": "1.0",
  "scenario_set_name": "trend_channel_reference_robustness_test",
  "created": "2026-06-26T08:42:19.692415+00:00",
  "description": "Didactic reference robustness set (#118 case study) \u2014 CORE/trend_channel_reference on mt5 EURUSD+GBPUSD, 36 windows (IS/OOS 0.3). Teaching example, NOT a profitable strategy: exercises the full order surface (resting LIMIT entries, SL/TP, trailing stop, partial close, multi-position) under multi-window IS/OOS validation.",
  "robustness": {
    "enabled": true,
    "metric": "expectancy",
    "oos_split": 0.3,
    "min_windows": 3,
    "overfit_wfe_threshold": 0.5,
    "robust_wfe_threshold": 0.8,
    "disposition_trust_pct": 25.0
  },
  "global": {
    "data_mode": "realistic",
    "strategy_config": {
      "decision_logic_type": "CORE/trend_channel_reference",
      "worker_instances": {
        "h1_trend": "CORE/ma_trend",
        "m15_channel": "CORE/bollinger"
      },
      "workers": {
        "h1_trend": {
          "periods": {
            "H1": 50
          },
          "ma_type": "ema",
          "neutral_band": 0.05,
          "recompute": "bar_close",
          "include_current_bar": false
        },
        "m15_channel": {
          "periods": {
            "M15": 20
          },
          "deviation": 2.0
        }
      },
      "decision_logic_config": {
        "entry_mode": "limit_pullback",
        "entry_band_pos": 0.15,
        "breakout_offset_mult": 0.25,
        "sl_mult": 1.0,
        "tp_mult": 2.0,
        "trail_mult": 1.0,
        "partial_rr": 1.0,
        "partial_fraction": 0.5,
        "max_positions": 2,
        "lot_size": 0.1,
        "min_free_margin": 1000
      }
    },
    "execution_config": {},
    "trade_simulator_config": {
      "balances": {
        "USD": 10000.0
      }
    },
    "stress_test_config": {}
  },
