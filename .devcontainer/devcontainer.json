{
    "name": "FiniexTestingIDE Dev",
    // To enable the FiniexViewer visual frontend: see docs/user_guides/finiexviewer_setup.md
    "dockerComposeFile": "../docker-compose.yml",
    "service": "finiex-dev",
    "workspaceFolder": "/app",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.debugpy",
                "Vue.volar"
            ],
            "settings": {
                "python.defaultInterpreterPath": "/usr/local/bin/python",
                "python.terminal.activateEnvironment": false
            }
        }
    },
    "forwardPorts": [],
    //"postCreateCommand": "pip install -e .",
    "remoteUser": "root"
}